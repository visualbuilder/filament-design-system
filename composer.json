{
    "name": "visualbuilder/filament-design-system",
    "description": "A Filament v5 design-system review panel and AI-friendly theme designer.",
    "keywords": [
        "visualbuilder",
        "filament",
        "design-system",
        "theme"
    ],
    "homepage": "https://github.com/visualbuilder/filament-design-system",
    "license": "GPL-2.0-or-later",
    "type": "library",
    "authors": [
        {
            "name": "Visual Builder",
            "email": "support@ekouk.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "suggest": {
        "visualbuilder/lottie": "Adds the Animations catalogue page demonstrating the Lottie schema component."
    },
    "require-dev": {
        "orchestra/testbench": "^9.0 || ^10.0",
        "pestphp/pest": "^3.0 || ^4.0",
        "pestphp/pest-plugin-laravel": "^3.0 || ^4.0",
        "pestphp/pest-plugin-livewire": "^4.0",
        "phpstan/extension-installer": "^1.3",
        "phpstan/phpstan-deprecation-rules": "^1.1",
        "phpstan/phpstan-phpunit": "^1.3",
        "phpunit/phpunit": "^11.0 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "Visualbuilder\\FilamentDesignSystem\\": "src",
            "Visualbuilder\\FilamentDesignSystem\\Database\\Factories\\": "database/factories/",
            "Visualbuilder\\FilamentDesignSystem\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Visualbuilder\\FilamentDesignSystem\\Tests\\": "tests"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Visualbuilder\\FilamentDesignSystem\\FilamentDesignSystemServiceProvider"
            ]
        },
        "branch-alias": {
            "5.x-dev": "5.0.x-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
